<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>IronTracks</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.9</string>
	<key>CFBundleVersion</key>
	<string>36</string>
	<key>LSRequiresIPhoneOS</key>
	<false/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>WKApplication</key>
	<true/>
	<key>WKCompanionAppBundleIdentifier</key>
	<string>com.irontracks.app</string>
	<key>WKWatchOnly</key>
	<false/>
	<key>WKBackgroundModes</key>
	<array>
		<string>workout-processing</string>
	</array>
	<key>NSHealthShareUsageDescription</key>
	<string>O IronTracks usa sua frequência cardíaca e dados de treino para acompanhar sua intensidade durante exercícios e cardio.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>O IronTracks salva seus treinos no app Saúde para que você possa ver seu progresso ao longo do tempo.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>O IronTracks usa o GPS do Apple Watch para registrar a rota das suas corridas e caminhadas.</string>
	<key>NSMotionUsageDescription</key>
	<string>O IronTracks usa o sensor de movimento para detectar atividade física durante treinos.</string>
</dict>
</plist>
