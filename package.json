{
  "name": "iron-tracks",
  "version": "4.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <23 || 22.x"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.8",
    "postcss": "^8.5.15"
  },
  "scripts": {
    "predev": "node scripts/ensure-next-compiled-commander.mjs",
    "prebuild": "node scripts/ensure-next-compiled-commander.mjs",
    "prestart": "node scripts/ensure-next-compiled-commander.mjs",
    "dev": "next dev --webpack --hostname localhost --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "node --import tsx ./node_modules/eslint/bin/eslint.js --config eslint.config.mjs .",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "tsx scripts/delete-teacher-cascade.test.ts && tsx scripts/vip-entitlement.test.ts && tsx scripts/admin-routes-smoke.test.ts && tsx scripts/auth-origin-smoke.test.ts && tsx scripts/no-duplicate-style-files.test.ts && tsx scripts/vip-endpoints-no-dup.test.ts && tsx scripts/no-direct-req-json.test.ts && tsx scripts/workouts-history-enforcement.test.ts && tsx scripts/finish-payload-smoke.test.ts && tsx scripts/push-multiplatform-smoke.test.ts && tsx scripts/stories-integrity-smoke.test.ts && tsx scripts/rls-policies-smoke.test.ts && tsx scripts/mercadopago-webhook-smoke.test.ts && tsx scripts/revenuecat-webhook-smoke.test.ts && tsx scripts/billing-revenuecat-provider-smoke.test.ts && tsx scripts/ai-gating-smoke.test.ts && tsx scripts/finish-workout-integration.test.ts && tsx scripts/teacher-inbox-integration.test.ts && tsx scripts/profiles-public-view-smoke.test.ts && tsx scripts/medium-hardening-smoke.test.ts && tsx scripts/bia-attachment-private-smoke.test.ts && tsx scripts/low-hardening-smoke.test.ts",
    "flags:report": "NODE_NO_WARNINGS=1 tsx scripts/feature-flags-report.ts",
    "deploy": "npx tsc --noEmit && git add -u && git add src/ scripts/ supabase/ public/ package.json package-lock.json && (git diff-index --quiet HEAD || git commit -m \"deploy: $(date +%Y-%m-%d-%H%M)\") && git push origin main",
    "e2e:deload": "tsx scripts/e2e/deload.e2e.ts",
    "postversion": "git push && git push --tags",
    "postinstall": "node scripts/patch-ios.mjs",
    "cap:sync": "npx cap sync && node scripts/patch-ios.mjs",
    "cap:sync:android": "npx cap sync android",
    "cap:open": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "ios:release": "bash scripts/ios-release.sh",
    "ios:submit": "node scripts/ios-submit.mjs",
    "android:release": "bash scripts/android-release.sh",
    "android:submit": "node scripts/android-submit.mjs",
    "analyze": "ANALYZE=true npm run build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test --reporter=github",
    "scan:buttons": "node scripts/scan-buttons-static.mjs",
    "scan:buttons:critical": "node scripts/scan-buttons-static.mjs --only-critical",
    "scan:buttons:full": "playwright test e2e/authenticated-button-scan.spec.ts --reporter=list",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "scan:a11y": "node scripts/scan-a11y.mjs",
    "scan:async": "node scripts/scan-async-loading.mjs",
    "scan:async:critical": "node scripts/scan-async-loading.mjs --only-critical",
    "scan:console": "node scripts/scan-console.mjs",
    "scan:unicode": "node scripts/scan-unicode-escapes.mjs",
    "scan:all": "node scripts/scan-secrets.mjs && node scripts/scan-a11y.mjs && node scripts/scan-async-loading.mjs --only-critical && node scripts/scan-buttons-static.mjs --only-critical && node scripts/scan-unicode-escapes.mjs",
    "check:env": "npx tsx scripts/check-env.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@google/genai": "^2.9.0",
    "@revenuecat/purchases-capacitor": "^12.1.2",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/auth-js": "^2.108.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/leaflet": "^1.9.21",
    "@upstash/qstash": "^2.11.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/functions": "^3.7.1",
    "@vercel/speed-insights": "^1.3.1",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.21.3",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.559.0",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.7",
    "tus-js-client": "^4.3.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint-community/eslint-utils": "^4.9.1",
    "@eslint/config-array": "^0.23.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/node": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "baseline-browser-mapping": "^2.9.19",
    "chalk": "^5.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
