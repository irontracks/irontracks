# ──────────────────────────────────────────────────────────────────────────────
# IRONTRACKS — Environment Variables
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite .env.local (está no .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ==============================================================================
# SUPABASE
# Projeto: https://supabase.com/dashboard/project/SEU_PROJECT_ID
# Onde encontrar: Supabase dashboard > Project Settings > API
# ==============================================================================

# URL pública do projeto Supabase (obrigatória)
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (pública) do Supabase — segura para expor no cliente (obrigatória)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de service_role — acesso admin irrestrito ao banco (obrigatória)
# PRIVADA — nunca expor publicamente, usar apenas no servidor
SUPABASE_SERVICE_ROLE_KEY=

# Domínio para cookie de sessão do Supabase (opcional)
# ex: ".irontracks.com.br" para funcionar em todos os subdomínios
SUPABASE_COOKIE_DOMAIN=


# ==============================================================================
# APP / BASE URL
# ==============================================================================

# URL base do servidor (usada em Server Actions e redirects) (obrigatória)
# ex: https://app.irontracks.com.br
APP_BASE_URL=

# URL base pública (exposta ao cliente) (obrigatória)
# ex: https://www.irontracks.com.br
NEXT_PUBLIC_BASE_URL=

# Fallback/alias para APP_BASE_URL em alguns contextos internos (opcional)
# ex: https://app.irontracks.com.br
IRONTRACKS_PUBLIC_ORIGIN=


# ==============================================================================
# IA — GOOGLE GEMINI
# Onde encontrar: console.cloud.google.com > APIs & Services > Credentials
# (habilitar "Generative Language API" antes)
# ==============================================================================

# API key do Google Generative AI / Gemini (obrigatória)
# PRIVADA — nunca expor publicamente
GOOGLE_GENERATIVE_AI_API_KEY=

# ID do modelo Gemini a usar (opcional — o código tem fallback interno)
# ex: gemini-1.5-pro
GOOGLE_GENERATIVE_AI_MODEL_ID=


# ==============================================================================
# REVENUECAT / APPLE IAP
# Onde encontrar: app.revenuecat.com > Project > Apps / API Keys
# ==============================================================================

# Habilita o fluxo de IAP (obrigatória)
# "true" em produção/TestFlight | "false" em dev web
NEXT_PUBLIC_ENABLE_IAP=false

# API key pública para iOS (Capacitor/nativo) (obrigatória para mobile)
# RevenueCat dashboard > App > iOS API key
NEXT_PUBLIC_REVENUECAT_IOS_API_KEY=

# API key pública para web (obrigatória para web paywall)
# RevenueCat dashboard > App > Public API key
NEXT_PUBLIC_REVENUECAT_API_KEY=

# Secret key para validação server-side de webhooks e compras (obrigatória)
# PRIVADA — nunca expor publicamente
# RevenueCat dashboard > API Keys > Secret key
REVENUECAT_SECRET_API_KEY=

# Alias de REVENUECAT_SECRET_API_KEY — código aceita ambos (opcional se já definiu acima)
REVENUECAT_SECRET_KEY=

# ID do entitlement VIP no RevenueCat (obrigatória)
# Valor fixo neste projeto — não alterar sem atualizar o RevenueCat dashboard
REVENUECAT_ENTITLEMENT_ID=vip

# Token de autenticação do webhook do RevenueCat (obrigatória em produção)
# RevenueCat dashboard > Integrations > Webhooks > Authorization header
REVENUECAT_WEBHOOK_AUTH_KEY=


# ==============================================================================
# EMAIL — RESEND
# Onde encontrar: resend.com > API Keys
# ==============================================================================

# API key do Resend para envio de e-mails transacionais (obrigatória)
# PRIVADA — nunca expor publicamente
RESEND_API_KEY=

# Endereço "De" padrão nos e-mails enviados (obrigatória)
# ex: IronTracks <noreply@irontracks.com.br>
RESEND_FROM=


# ==============================================================================
# PUSH NOTIFICATIONS — FIREBASE CLOUD MESSAGING (Android / Web)
# Onde encontrar: console.firebase.google.com > Project Settings > Service accounts
# ==============================================================================

# ID do projeto Firebase (obrigatória para push Android/web)
FCM_PROJECT_ID=

# E-mail do service account do Firebase (obrigatória)
# Project Settings > Service accounts > Firebase service account email
FCM_CLIENT_EMAIL=

# Chave privada do service account do Firebase (obrigatória)
# PRIVADA — nunca expor publicamente
# Project Settings > Service accounts > Generate new private key
# Copiar o campo "private_key" do JSON gerado (manter \n escapados)
FCM_PRIVATE_KEY=


# ==============================================================================
# PUSH NOTIFICATIONS — APPLE PUSH NOTIFICATION SERVICE (iOS)
# Onde encontrar: developer.apple.com > Certificates, Identifiers & Profiles > Keys
# ==============================================================================

# Key ID da chave APNs criada no Apple Developer (obrigatória para push iOS)
# ex: ABCD1234EF
APNS_KEY_ID=

# Conteúdo do arquivo .p8 baixado do Apple Developer (obrigatória)
# PRIVADA — nunca expor publicamente
# Abrir o .p8 num editor, copiar tudo e escapar quebras de linha como \n
APNS_KEY_P=

# Team ID da conta Apple Developer (obrigatória)
# developer.apple.com > Account > Membership > Team ID (10 caracteres)
APNS_TEAM_ID=

# Bundle ID do app iOS (obrigatória)
APNS_BUNDLE_ID=com.irontracks.app

# Ambiente APNs (obrigatória)
# "true" em produção | "false" em sandbox / TestFlight
APNS_PRODUCTION=false


# ==============================================================================
# CLOUDINARY — UPLOAD E CDN DE MÍDIA
# Onde encontrar: cloudinary.com > Dashboard (canto superior)
# ==============================================================================

# Nome do cloud Cloudinary (obrigatória)
CLOUDINARY_CLOUD_NAME=

# API key do Cloudinary (obrigatória)
CLOUDINARY_API_KEY=

# API secret do Cloudinary (obrigatória)
# PRIVADA — nunca expor publicamente
CLOUDINARY_API_SECRET=


# ==============================================================================
# PAGAMENTOS — MERCADOPAGO
# Onde encontrar: mercadopago.com.br > Suas integrações > Credenciais
# ==============================================================================

# Access token de produção do MercadoPago (obrigatória)
# PRIVADA — nunca expor publicamente
# Usar APP_UST... de produção (não o de teste)
MERCADOPAGO_ACCESS_TOKEN=

# Secret para validação de assinatura dos webhooks do MercadoPago (obrigatória)
# PRIVADA — nunca expor publicamente
# Suas integrações > Webhooks > Chave secreta
MERCADOPAGO_WEBHOOK_SECRET=

# Chave PIX da conta MercadoPago para recebimentos via PIX (obrigatória)
# ex: email@dominio.com | CPF | CNPJ | chave aleatória
MERCADOPAGO_PIX_KEY=

# URL base da API do MercadoPago (opcional — padrão usado internamente)
# Padrão: https://api.mercadopago.com
MERCADOPAGO_BASE_URL=

# User-Agent customizado nas chamadas à API do MercadoPago (opcional)
# ex: IronTracks/1.0
MERCADOPAGO_USER_AGENT=


# ==============================================================================
# PAGAMENTOS — ASAAS (marketplace de professores)
# Onde encontrar: asaas.com > Configurações > Integrações
# ==============================================================================

# API key do ASAAS para criação de cobranças e subcontas (obrigatória)
# PRIVADA — nunca expor publicamente
ASAAS_API_KEY=

# Token de autenticação dos webhooks do ASAAS (obrigatória em produção)
# PRIVADA — nunca expor publicamente
# Configurações > Notificações > Webhook token
ASAAS_WEBHOOK_SECRET=

# URL base da API do ASAAS (opcional — padrão usado internamente)
# Padrão: https://api.asaas.com/v3
ASAAS_BASE_URL=

# User-Agent customizado nas chamadas à API do ASAAS (opcional)
# ex: IronTracks/1.0
ASAAS_USER_AGENT=


# ==============================================================================
# MARKETPLACE
# ==============================================================================

# Percentual de taxa da plataforma cobrada em cada transação do marketplace (obrigatória)
# ex: 10  (representa 10%)
MARKETPLACE_PLATFORM_FEE_PERCENT=


# ==============================================================================
# REDIS — UPSTASH (rate limiting distribuído)
# Onde encontrar: console.upstash.com > Database selecionado > REST API
# ==============================================================================

# URL REST do banco Redis no Upstash (obrigatória)
UPSTASH_REDIS_REST_URL=

# Token REST de autenticação do Upstash (obrigatória)
# PRIVADA — nunca expor publicamente
UPSTASH_REDIS_REST_TOKEN=


# ==============================================================================
# SEGURANÇA — SECRETS INTERNOS
# ==============================================================================

# Secret para autenticar chamadas de cron jobs (obrigatória)
# Gerar com: openssl rand -hex 32
# Usar o mesmo valor em cada chamada: Authorization: Bearer $CRON_SECRET
CRON_SECRET=

# Secret para autenticação interna entre serviços/edge functions (obrigatória)
# Gerar com: openssl rand -hex 32
# PRIVADA — nunca expor publicamente
IRONTRACKS_INTERNAL_SECRET=

# E-mail do administrador principal da plataforma (obrigatória)
# ex: admin@irontracks.com.br
IRONTRACKS_ADMIN_EMAIL=

# Alias/fallback de IRONTRACKS_ADMIN_EMAIL em contextos legados (opcional)
ADMIN_EMAIL=

# Profundidade de proxy confiável para extração do IP real (obrigatória)
# "1" para Vercel / Cloudflare (1 hop de proxy confiável)
TRUSTED_PROXY_DEPTH=1


# ==============================================================================
# YOUTUBE
# Onde encontrar: console.cloud.google.com > APIs & Services > Credentials
# (habilitar "YouTube Data API v3" antes)
# ==============================================================================

# API key do YouTube Data API v3 (obrigatória para busca de vídeos de exercícios)
# PRIVADA — nunca expor publicamente
YOUTUBE_API_KEY=


# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Habilita gravação de vídeo de execução de exercícios — server-side (opcional)
# "true" para habilitar | "false" para desabilitar
ENABLE_EXECUTION_VIDEO=false

# Habilita gravação de vídeo de execução — client-side (opcional)
# "true" para habilitar | "false" para desabilitar
NEXT_PUBLIC_ENABLE_EXECUTION_VIDEO=false

# Provider de upload de mídia (obrigatória se usar upload de mídia)
# "cloudinary" | "supabase"
NEXT_PUBLIC_STORAGE_PROVIDER=cloudinary

# Bundle ID para Sign in with Apple no cliente (obrigatória para auth Apple)
# ex: com.irontracks.app
NEXT_PUBLIC_APPLE_IOS_CLIENT_ID=com.irontracks.app

# Versão do app exibida na UI e enviada ao Sentry (opcional)
# ex: 1.0.0 — pode ser gerado automaticamente pelo CI/CD
NEXT_PUBLIC_APP_VERSION=


# ==============================================================================
# VERCEL — injetadas automaticamente em produção
# NÃO definir manualmente — o Vercel já injeta esses valores no build
# ==============================================================================

# ID do deployment atual no Vercel (auto-injetada pelo Vercel — não definir)
# VERCEL_DEPLOYMENT_ID=

# SHA do commit Git do deployment atual (auto-injetada pelo Vercel — não definir)
# VERCEL_GIT_COMMIT_SHA=
