{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "types": [
            "vitest/globals",
            "@testing-library/jest-dom"
        ]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/__tests__/**/*.ts",
        "src/__tests__/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        ".next",
        "ios",
        "android"
    ]
}