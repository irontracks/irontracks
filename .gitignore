# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# trae
.trae

# local assistants
.claude

# MCP server config (contains tokens)
.mcp.json

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# accidental duplicate files created by the editor (spaces in name)
**/* *.ts
**/* *.tsx

# build & debug artifacts — should never be committed
lint-out.txt
deploy_full_log.txt
*.debug.json
push_bg.sh

# Playwright auth state
e2e/.auth/

# iOS build artifacts & Xcode package caches
ios/App/build/
ios/App/DerivedData/
ios/App/*.xcworkspace/xcshareddata/
ios/App/*.xcworkspace/xcuserdata/
ios/App/Pods/
ios/App/build/SourcePackages/
ios/LocalPackages/capacitor-swift-pm/
ios/LocalPackages/purchases-hybrid-common/
ios/LocalPackages/purchases-ios-spm/
*.dSYM
*.dSYM/

# Android build artifacts
android/app/build/
android/build/
android/.gradle/
android/.gradle-local/

# Capacitor Cordova plugin resources (auto-generated)
ios/capacitor-cordova-ios-plugins/resources/
android/capacitor-cordova-android-plugins/

# Accidental duplicate folders created by editor (spaces in name)
**/* 2/
**/* 2.ts
**/* 2.tsx
**/* 2.css
**/* 2.json
**/* 2.txt
