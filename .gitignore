# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Service account JSONs (Play Developer API, Firebase Admin, etc.)
**/service-accounts/*.json
**/google-play-*.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/.playwright-mcp

# dev/debug screenshots soltos na raiz (não versionar)
/test_*.png
/prod_*.png
/paywall_*.png
/review_screenshot.png
/vercel_*.png
/tmp_screenshot_*.txt

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# trae
.trae

# local assistants
.claude

# MCP server config (contains tokens)
.mcp.json

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# accidental duplicate files created by the editor (spaces in name)
**/* *.ts
**/* *.tsx

# build & debug artifacts — should never be committed
lint-out.txt
deploy_full_log.txt
*.debug.json
push_bg.sh

# Playwright auth state
e2e/.auth/

# iOS build artifacts & Xcode package caches
ios/App/build/
ios/App/DerivedData/
ios/App/*.xcworkspace/xcshareddata/
ios/App/*.xcworkspace/xcuserdata/
ios/App/Pods/
ios/App/build/SourcePackages/
ios/LocalPackages/capacitor-swift-pm/
ios/LocalPackages/purchases-hybrid-common/
ios/LocalPackages/purchases-ios-spm/
*.dSYM
*.dSYM/

# Android build artifacts
android/app/build/
android/build/
android/.gradle/
android/.gradle-local/

# Capacitor Cordova plugin resources (auto-generated)
ios/capacitor-cordova-ios-plugins/resources/
android/capacitor-cordova-android-plugins/

# Accidental duplicate folders created by editor (spaces in name)
**/* 2/
**/* 2.ts
**/* 2.tsx
**/* 2.css
**/* 2.json
**/* 2.txt

# RevenueCat dashboard DOM snapshots (not IaC, have no value checked in)
/rc-*.yml

# Sentry DSN per-build config (committado: Sentry.xcconfig.example)
ios/App/App/Sentry.xcconfig

# ios-native (Tuist) generated files and Xcode user state
ios-native/**/Derived/
ios-native/**/xcuserdata/
ios-native/**/xcshareddata/swiftpm/
ios-native/DerivedData/
ios-native/build/
ios-native/.build/
.worktrees/
scripts/taco-data.json
knowledge-base/

# Changelog automático gerado por hook local do Claude Code
CLAUDE_CHANGES.md

# Codex config local — contém secrets reais (GCP/GitHub/Supabase PAT), nunca commitar
.codex/
